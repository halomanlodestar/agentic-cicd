{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@rift/types": ["../types/src/index.ts"],
      "@rift/docker": ["../docker/src/index.ts"]
    }
  },
  "include": ["src"]
}
